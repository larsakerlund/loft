# Copy to .env and fill in for a real deployment. The local docker-compose loop needs none of these
# (it runs in dev mode, LOFT_DEV=1, with a hard-coded user). These configure loftd against your own
# database, identity provider, LLM endpoint, and upload storage. The defaults are platform-neutral;
# Azure is one set of options, not a requirement.

# --- identity (any standard OIDC provider) ---
# The proxy in front of loftd forwards a validated access token; loftd validates it against this
# issuer + audience. Use the bare issuer URL (loftd appends /.well-known/openid-configuration).
LOFT_OIDC_ISSUER=https://your-idp.example.com
LOFT_API_AUDIENCE=your-loft-api-id
# LOFT_API_SCOPE=access_as_user            # required delegated scope on the access token
# LOFT_AUTHORIZED_CLIENT_ID=               # if set, the token's azp/appid must equal this

# --- CLI discovery (optional; advertised at /.well-known/loft so `loft login <url>` self-configures) ---
# LOFT_CLI_CLIENT_ID=your-cli-public-client-id
# LOFT_CLI_SCOPE=openid offline_access your-loft-api-scope

# --- database (Postgres) ---
LOFT_PG_CONNECTION_STRING=postgres://user:pass@host:5432/loft?sslmode=require
# Or, for Azure managed-identity (keyless) auth, set host+user instead of the connection string:
# LOFT_PG_HOST=psql-host.postgres.database.azure.com
# LOFT_PG_USER=loft-app
# LOFT_PG_DATABASE=loft
# LOFT_UAMI_CLIENT_ID=                      # Azure user-assigned managed identity client id

# --- LLM (loft.ai) ---
# OpenAI-compatible endpoint (OpenAI, Groq, Together, vLLM, Ollama, LiteLLM):
LOFT_AI_ENDPOINT=https://api.openai.com/v1
LOFT_AI_MODEL=gpt-4o-mini
LOFT_AI_KEY=sk-...
# Or Azure OpenAI / AI Foundry (set the deployment instead of the model):
# LOFT_AI_ENDPOINT=https://your-resource.openai.azure.com/
# LOFT_AI_DEPLOYMENT=your-deployment
# LOFT_AI_API_VERSION=2025-04-01-preview
# LOFT_AI_REASONING_EFFORT=low             # only for reasoning models that accept it

# --- uploads (loft.upload) ---
# A local directory (single node), or Azure Blob via account (managed identity) or a connection string:
LOFT_UPLOADS_DIR=/mnt/uploads
# LOFT_UPLOADS_ACCOUNT=your-storage-account
# LOFT_UPLOADS_CONTAINER=uploads
# LOFT_UPLOADS_CONNECTION_STRING=

# --- sites storage ---
# Where loftd writes deployed sites; the ingress serves them. A shared filesystem mount.
LOFT_SITES_DIR=/mnt/loft

# --- deploy CLI (on the developer's machine, not loftd) ---
# LOFT_URL=https://loft.example.com        # the platform URL (or `loft login <url>`)
# LOFT_TOKEN=                              # a bearer token for CI instead of `loft login`
